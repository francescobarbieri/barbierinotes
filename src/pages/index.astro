---
import Layout from '../layouts/Layout.astro';

const allPosts = await Astro.glob('../pages/posts/*.md');

---

<Layout title="Barbieri Notes">
	<main>
		<div>
			<span class="mb-5 block font-medium sm:mb-6">About me</span>
			<p>I'm a Computer Science student at the University of Milano-Bicocca. Currently I'm prioritizing valuable work experience working as a Freelance Developer while studying.</p>
			<p class="mt-4">My primary objective is to meet like-minded individuals and build something useful and, possibly, cool. Learn more about me here.</p>
		</div>

		<div class="-mb-3 mt-16 sm:mt-32">
			<span class="mb-5 block font-medium sm:mb-6">Essay</span>
			<div class="flex flex-col gap-7 sm:gap-4">
				<a href="https://animations.dev/" target="_blank" class="-mx-3 flex flex-col rounded-md px-3 no-underline hover:bg-[#F5F4F4] dark:hover:bg-gray-200 sm:py-3"><span>Animations on the web</span><span class="text-gray-1100">Learn how to craft animations that make people feel something.</span></a>
				<a href="https://animations.dev/" target="_blank" class="-mx-3 flex flex-col rounded-md px-3 no-underline hover:bg-[#F5F4F4] dark:hover:bg-gray-200 sm:py-3"><span>Animations on the web</span><span class="text-gray-1100">Learn how to craft animations that make people feel something.</span></a>
			</div>
		</div>

		<div class="-mb-3 mt-16 sm:mt-32">
			<span class="mb-5 block font-medium sm:mb-6">More</span>
			<p>You can see more of my work on X (Twitter) or more of my code in GitHub</p>
		</div>
	</main>
</Layout>
